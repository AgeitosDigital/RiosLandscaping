# Supabase — https://supabase.com/dashboard/project/mvwssjrvreememnhrsbr/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://mvwssjrvreememnhrsbr.supabase.co
# Publishable key (starts with sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (starts with sb_secret_...) — server-only, no NEXT_PUBLIC_ prefix
SUPABASE_SECRET_KEY=

# Resend — https://resend.com/api-keys (sends quote notifications to SITE.email)
RESEND_API_KEY=
# Optional custom from address after verifying your domain in Resend
# RESEND_FROM_EMAIL=Rios Landscaping <quotes@rioslandscaping.co>

# Site
NEXT_PUBLIC_SITE_URL=https://rioslandscaping.co
