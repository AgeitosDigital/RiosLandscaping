# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Where quote emails are delivered (defaults to SITE.email in code)
# QUOTE_NOTIFICATION_EMAIL=Srevirgr4@gmail.com
# Required after verifying rioslandscaping.co at https://resend.com/domains
# RESEND_FROM_EMAIL=Rios Landscaping <quotes@rioslandscaping.co>
# Until domain is verified, Resend only sends to your account email — use as fallback:
# RESEND_FALLBACK_EMAIL=your-resend-account@email.com

# Site
NEXT_PUBLIC_SITE_URL=https://rioslandscaping.co
